# ─── Backend ─────────────────────────────────────────────────────────────
APP_ENV=development                 # development | staging | production
APP_PORT=8080
APP_LOG_LEVEL=debug                 # debug | info | warn | error

# Database
DATABASE_URL=postgres://shop:shop@localhost:5432/shop?sslmode=disable

# Session / cookies
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false         # false in dev only; MUST be true in prod
SESSION_TTL=168h                    # 7 days

# CSRF
CSRF_KEY=change-me-to-a-32-byte-random-hex-string-abcdef0123456789abcdef01

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_RPS=20
RATE_LIMIT_LOGIN_RPM=10

# ─── Object storage (S3-compatible: MinIO in dev, Cloudflare R2 in prod) ─
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=shopminio
S3_SECRET_KEY=shopminio-secret
S3_BUCKET=shop-media
S3_PUBLIC_URL_BASE=http://localhost:9000/shop-media
S3_FORCE_PATH_STYLE=true

# For Cloudflare R2 in prod, use:
#   S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_ACCESS_KEY=<R2 access key>
#   S3_SECRET_KEY=<R2 secret>
#   S3_BUCKET=<your bucket>
#   S3_PUBLIC_URL_BASE=https://cdn.yourshop.com   # public bucket or Cloudflare Worker
#   S3_FORCE_PATH_STYLE=false

# ─── Admin (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Storefront (Next.js) ────────────────────────────────────────────────
# (same NEXT_PUBLIC_API_URL)
