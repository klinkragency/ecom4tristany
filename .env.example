# ─── Backend ─────────────────────────────────────────────────────────────
APP_ENV=development                 # development | staging | production
APP_PORT=8080
APP_LOG_LEVEL=debug                 # debug | info | warn | error

# Database
DATABASE_URL=postgres://shop:shop@localhost:5432/shop?sslmode=disable

# Session / cookies
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false         # false in dev only; MUST be true in prod
SESSION_TTL=168h                    # 7 days

# CSRF
CSRF_KEY=change-me-to-a-32-byte-random-hex-string-abcdef0123456789abcdef01

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_RPS=20
RATE_LIMIT_LOGIN_RPM=10

# ─── Object storage : Cloudflare R2 ──────────────────────────────────────
# Créer un bucket + API token : https://dash.cloudflare.com → R2 → Manage API Tokens
# Activer l'accès public : R2 → ton bucket → Settings → Public access → Allow Access
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=<R2 Access Key ID>
S3_SECRET_KEY=<R2 Secret Access Key>
S3_BUCKET=<nom du bucket>
S3_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
S3_FORCE_PATH_STYLE=false

# ─── Admin (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Storefront (Next.js) ────────────────────────────────────────────────
# (same NEXT_PUBLIC_API_URL)
